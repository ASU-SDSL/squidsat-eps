mainmenu "EPS Application"

source "Kconfig.zephyr"

menu "EPS options"

choice EPS_NODE_ROLE
	prompt "EPS node role"
	default EPS_NODE_A

config EPS_NODE_A
	bool "Node A"

config EPS_NODE_B
	bool "Node B"

endchoice

config EPS_CAN_LOOPBACK
	bool "Enable CAN loopback mode for self-test"
	default n

config EPS_TX_PERIOD_MS
	int "TX period in milliseconds"
	default 1000
	range 10 60000

endmenu
